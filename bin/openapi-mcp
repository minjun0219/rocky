#!/usr/bin/env bun
/**
 * openapi-mcp 단독 CLI entry. 가벼운 인자 파싱 (`--config <path>`,
 * `--log-level <level>`, `--insecure-tls`, `-V`/`--version`, `-h`/`--help`)
 * 후 stdio MCP 서버를 띄운다. 의존성 회피를 위해 commander 를 쓰지 않는다.
 *
 * 설치 / 실행 예시:
 *   bun link                                      # 한 번만
 *   openapi-mcp --config ~/.config/openapi-mcp/openapi-mcp.json
 *   bunx openapi-mcp --config ./openapi-mcp.yaml
 */

import path from "node:path";
import {
  ConfigError,
  defaultConfigPath,
  loadConfig,
} from "../src/core/config-loader";
import { initLogger, type LogLevel } from "../src/core/logger";
import {
  SERVER_NAME,
  SERVER_VERSION,
  startStdioServer,
} from "../src/standalone";

interface CliOptions {
  config?: string;
  logLevel?: LogLevel;
  insecureTls?: boolean;
  showVersion?: boolean;
  showHelp?: boolean;
}

const VALID_LOG_LEVELS: ReadonlySet<string> = new Set([
  "trace",
  "debug",
  "info",
  "warn",
  "error",
  "fatal",
  "silent",
]);

function parseArgs(argv: string[]): CliOptions {
  const opts: CliOptions = {};
  for (let i = 0; i < argv.length; i += 1) {
    const a = argv[i];
    if (a === "-h" || a === "--help") {
      opts.showHelp = true;
      continue;
    }
    if (a === "-V" || a === "--version") {
      opts.showVersion = true;
      continue;
    }
    if (a === "--insecure-tls") {
      opts.insecureTls = true;
      continue;
    }
    if (a === "-c" || a === "--config") {
      const next = argv[i + 1];
      if (!next) throw new Error(`${a} requires a path argument`);
      opts.config = next;
      i += 1;
      continue;
    }
    if (a === "-l" || a === "--log-level") {
      const next = argv[i + 1];
      if (!next) throw new Error(`${a} requires a level argument`);
      if (!VALID_LOG_LEVELS.has(next)) {
        throw new Error(
          `--log-level must be one of ${[...VALID_LOG_LEVELS].join(", ")}`,
        );
      }
      opts.logLevel = next as LogLevel;
      i += 1;
      continue;
    }
    if (a?.startsWith("--config=")) {
      opts.config = a.slice("--config=".length);
      continue;
    }
    if (a?.startsWith("--log-level=")) {
      const value = a.slice("--log-level=".length);
      if (!VALID_LOG_LEVELS.has(value)) {
        throw new Error(
          `--log-level must be one of ${[...VALID_LOG_LEVELS].join(", ")}`,
        );
      }
      opts.logLevel = value as LogLevel;
      continue;
    }
    throw new Error(`unknown argument: ${a}`);
  }
  return opts;
}

function printHelp(): void {
  // stderr 로 출력 — stdout 은 stdio MCP JSON-RPC 전용.
  process.stderr.write(
    `${SERVER_NAME} ${SERVER_VERSION}\n` +
      `\n` +
      `Usage: ${SERVER_NAME} [options]\n` +
      `\n` +
      `Options:\n` +
      `  -c, --config <path>      설정 파일 경로 (default: ${defaultConfigPath()})\n` +
      `  -l, --log-level <level>  trace|debug|info|warn|error|fatal|silent (default info)\n` +
      `  --insecure-tls           TLS 인증서 검증 비활성화 (사내 self-signed)\n` +
      `  -V, --version            버전 출력\n` +
      `  -h, --help               도움말\n`,
  );
}

async function main(): Promise<void> {
  let opts: CliOptions;
  try {
    opts = parseArgs(process.argv.slice(2));
  } catch (err) {
    process.stderr.write(`${(err as Error).message}\n`);
    printHelp();
    process.exit(2);
  }

  if (opts.showHelp) {
    printHelp();
    return;
  }
  if (opts.showVersion) {
    process.stdout.write(`${SERVER_VERSION}\n`);
    return;
  }

  const logger = initLogger(opts.logLevel ?? "info");
  const configPath = opts.config ?? defaultConfigPath();

  try {
    const { config, path: resolved } = await loadConfig(configPath);
    if (opts.insecureTls) {
      logger.warn("TLS certificate verification disabled (--insecure-tls)");
      config.http = { ...(config.http ?? {}), insecureTls: true };
    }
    logger.info(
      { config: resolved, specs: Object.keys(config.specs) },
      "config loaded",
    );
    await startStdioServer(config, { configDir: path.dirname(resolved) });
  } catch (err) {
    if (err instanceof ConfigError) {
      logger.error({ err: err.message }, "failed to load config");
    } else {
      logger.error({ err }, "fatal error during startup");
    }
    process.exit(1);
  }
}

void main();
