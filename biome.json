{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "files": {
    "includes": ["**", "!.sisyphus", "!.claude", "!.archive"]
  },
  "assist": {
    "enabled": false
  },
  "linter": {
    "rules": {
      "recommended": true,
      "complexity": {
        "noUselessSwitchCase": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      },
      "suspicious": {
        "noExplicitAny": "off"
      }
    }
  }
}
