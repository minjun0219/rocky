{
  "name": "@minjun0219/agent-toolkit-opencode",
  "version": "0.3.0",
  "description": "agent-toolkit opencode plugin. Exposes the 7 openapi_* tools (cache-first OpenAPI / Swagger inspection) via opencode's plugin API. Installed via git URL or npm.",
  "license": "MIT",
  "author": "Minjun Kim",
  "homepage": "https://github.com/minjun0219/agent-toolkit/tree/main/packages/agent-toolkit-opencode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minjun0219/agent-toolkit.git",
    "directory": "packages/agent-toolkit-opencode"
  },
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/index.ts"
  },
  "files": [
    "src",
    "INSTALL.md",
    "README.md"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "openapi",
    "swagger",
    "opencode",
    "plugin",
